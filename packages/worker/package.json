{
  "name": "@ravenscope/worker",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:apply:local": "wrangler d1 migrations apply DB --local",
    "db:apply:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.12"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.31",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.3",
    "vitest": "2.1.8",
    "wrangler": "^3.91.0"
  }
}
