# Template for packages/worker/wrangler.toml. The real wrangler.toml
# is gitignored so each deployment owns its own database_id,
# EMAIL_FROM, and OPERATOR_EMAIL. Two ways to materialize it:
#
#   - Local: run scripts/setup.sh — copies this template to
#     wrangler.toml (if missing) and prompts for each placeholder
#     value.
#   - CI: .github/workflows/deploy.yml renders this template into
#     wrangler.toml using repository Variables (D1_DATABASE_ID,
#     EMAIL_FROM, OPERATOR_EMAIL) before invoking wrangler deploy.

name = "ravenscope"
main = "src/index.ts"
compatibility_date = "2026-04-17"
compatibility_flags = ["nodejs_compat"]

[assets]
directory = "../web/dist"
binding = "ASSETS"
not_found_handling = "single-page-application"
# Route /api/* and /v/* to the Worker before consulting static assets.
# Without this, the SPA fallback serves index.html for any unmatched path
# INCLUDING /api/auth/verify and /v/:id/*, and the Hono handler never
# runs. Observable as a 200 with Content-Type: text/html on API endpoints
# (and no Set-Cookie on verify, breaking the magic-link flow). /v/* hosts
# the embedded AdvantageScope Lite viewer (see src/routes/advantagescope.ts).
run_worker_first = ["/api/*", "/v/*"]

[[durable_objects.bindings]]
name = "SESSION_INGEST_DO"
class_name = "SessionIngestDO"

[[durable_objects.bindings]]
name = "RATE_LIMIT_DO"
class_name = "RateLimitDO"

[[migrations]]
tag = "v1"
# Free-plan Workers require SQLite-backed DOs; `new_classes` only works on
# paid. `new_sqlite_classes` is the right migration kind for both free and
# paid, and matches the `useSQLite: true` miniflare config in vitest.
new_sqlite_classes = ["SessionIngestDO", "RateLimitDO"]

[[d1_databases]]
binding = "DB"
database_name = "ravenscope"
database_id = "REPLACE_ME_AFTER_wrangler_d1_create"
migrations_dir = "migrations"

[[r2_buckets]]
binding = "BLOBS"
bucket_name = "ravenscope-blobs"
# preview_bucket_name is only required for `wrangler dev --remote`; local dev
# synthesizes an in-memory R2 bucket.

[vars]
# Set by setup.sh from a Resend-verified sender domain. The
# `…example.com` placeholder is a sentinel that triggers the prompt;
# don't deploy with this committed value.
EMAIL_FROM = "no-reply@ravenscope.example.com"
# Receives daily-cap breach alerts (one email per metric per day). Empty
# string disables alerts; 429 enforcement still fires. Set per-deployment
# by setup.sh (or leave empty if you don't want alerts).
OPERATOR_EMAIL = ""

# Secrets (set via `wrangler secret put`):
#   SESSION_SECRET — JSON map {"v1":"<32-byte-base64>"}
#   RESEND_API_KEY
